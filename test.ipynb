   ],
   "source": [
    "x = np.arange(0,100,0.1)\n",
    "y = np.sin(x)\n",
    "plt.figure(figsize=(20,3))\n",
    "plt.plot(x,y)\n",
    "plt.xlabel(\"x\")\n",
    "plt.ylabel(\"sin(x)\")\n",
    "plt.title(\"Sine Wave\")\n",
    "plt.show()"
   ]
